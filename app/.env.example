# .env - Configuración corregida

# ============================================
# CONFIGURACIÓN DE OLLAMA
# ============================================

# URL base de Ollama (normalmente no necesitas cambiar esto)
OLLAMA_BASE_URL=http://localhost:11434

# ============================================
# CONFIGURACIÓN POR DEFECTO
# ============================================

# Configuración por defecto para generación de prompts
DEFAULT_STYLE=Fotorrealista
DEFAULT_QUALITY=4K Ultra HD

# =============================================================================
# CONFIGURACIÓN DE RAG - CORREGIDA
# =============================================================================
# IMPORTANTE: No usar ":latest" en el nombre del modelo para embeddings
# El sistema detectará automáticamente la versión disponible

# Modelo principal para embeddings RAG (sin :latest)
RAG_MODEL=nomic-embed-text

# Modelo de respaldo si el principal no está disponible
RAG_FALLBACK_MODEL=llama2

# Lista de modelos de embeddings en orden de preferencia
# (el sistema probará en este orden)
RAG_PREFERRED_MODELS=nomic-embed-text,all-minilm,llama2,llama3

# =============================================================================
# CONFIGURACIÓN OPCIONAL
# =============================================================================
# Puerto para la aplicación Streamlit (opcional)
# STREAMLIT_PORT=8501

# Configuración de caché (opcional)
# CACHE_ENABLED=True

# Directorio personalizado para guardar imágenes (opcional)
# CUSTOM_IMAGE_DIR=custom_images

# Configuración de GPU (opcional)
# FORCE_CPU=False
# GPU_MEMORY_FRACTION=0.8

# Configuración de chunking para RAG
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Número máximo de documentos relevantes para contexto
MAX_RELEVANT_DOCS=3